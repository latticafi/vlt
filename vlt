#!/bin/bash
# vlt — Vault secret injector. Drop-in replacement for `infisical run`.
# Install: ./install.sh or vlt update
#
# Usage:
#   vlt login                  — authenticate to Vault
#   vlt run -- <command>       — inject secrets and run command
#   vlt run -e staging -- cmd  — use a specific environment
#   vlt status                 — check auth + config
#   vlt init                   — create .vlt.json in current directory
#
# Config:
#   Global: ~/.config/vlt/config.json (vault address + username, persists across logins)
#   Project: .vlt.json (per-repo, stores project name + secret paths)
set -euo pipefail
GLOBAL_CONFIG_DIR="$HOME/.config/vlt"
GLOBAL_CONFIG="$GLOBAL_CONFIG_DIR/config.json"
# Find project config file (walk up directories)
find_config() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/.vlt.json" ]; then
      echo "$dir/.vlt.json"
      return 0
    fi
    dir=$(dirname "$dir")
  done
  return 1
}
# Read a JSON key from a file
read_json() {
  local file="$1"
  local key="$2"
  local default="${3:-}"
  local value
  value=$(jq -r "$key // empty" "$file" 2>/dev/null)
  echo "${value:-$default}"
}
# Global config helpers
read_global() {
  local key="$1"
  if [ -f "$GLOBAL_CONFIG" ]; then
    read_json "$GLOBAL_CONFIG" "$key"
  fi
}
save_global() {
  local addr="$1"
  local username="$2"
  mkdir -p "$GLOBAL_CONFIG_DIR"
  cat >"$GLOBAL_CONFIG" <<EOF
{
  "addr": "${addr}",
  "username": "${username}"
}
EOF
}
# Resolve Vault address (project config → global config → prompt)
resolve_addr() {
  local addr=""
  # 1. Try project .vlt.json
  if config_file=$(find_config 2>/dev/null); then
    addr=$(read_json "$config_file" '.addr')
  fi
  # 2. Try global config
  if [ -z "$addr" ]; then
    addr=$(read_global '.addr')
  fi
  # 3. Prompt
  if [ -z "$addr" ]; then
    read -rp "Vault address (e.g. https://vault.example.com): " addr
    if [ -z "$addr" ]; then
      echo "Error: Vault address is required" >&2
      exit 1
    fi
  fi
  echo "$addr"
}
# Commands
cmd_init() {
  if [ -f ".vlt.json" ]; then
    echo "Error: .vlt.json already exists in this directory"
    exit 1
  fi
  local addr=""
  local project=""
  # Use saved address if we have one, only prompt if we don't
  addr=$(read_global '.addr')
  if [ -z "$addr" ]; then
    read -rp "Vault address (e.g. https://vault.example.com): " addr
    if [ -z "$addr" ]; then
      echo "Error: Vault address is required"
      exit 1
    fi
  else
    echo "Using Vault at ${addr}"
  fi
  read -rp "Project name (e.g. rest-api, web-app): " project
  if [ -z "$project" ]; then
    echo "Error: project name is required"
    exit 1
  fi
  cat >.vlt.json <<EOF
{
  "addr": "${addr}",
  "project": "${project}",
  "environments": {
    "dev": "secret/data/dev/${project}",
    "staging": "secret/data/staging/${project}",
    "prod": "secret/data/prod/${project}"
  },
  "default_env": "dev"
}
EOF
  echo ""
  echo "Created .vlt.json:"
  echo ""
  cat .vlt.json
  echo ""
  echo "Commit this file so your team shares the config."
}
cmd_login() {
  local addr
  addr=$(resolve_addr)
  # Default to saved username
  local username=""
  local saved_username
  saved_username=$(read_global '.username')
  if [ -n "$saved_username" ]; then
    read -rp "Username [${saved_username}]: " username
    username="${username:-$saved_username}"
  else
    read -rp "Username: " username
    if [ -z "$username" ]; then
      echo "Error: username is required"
      exit 1
    fi
  fi
  # Save for next time
  save_global "$addr" "$username"
  export VAULT_ADDR="$addr"
  echo "Logging in to ${addr}..."
  vault login -method=userpass username="$username"
}
cmd_run() {
  local env=""
  local args=()
  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -e | --env)
      env="$2"
      shift 2
      ;;
    --)
      shift
      args=("$@")
      break
      ;;
    *)
      args=("$@")
      break
      ;;
    esac
  done
  if [ ${#args[@]} -eq 0 ]; then
    echo "Error: no command specified"
    echo "Usage: vlt run [-e env] -- <command>"
    exit 1
  fi
  # Find and read project config
  local config_file
  if ! config_file=$(find_config); then
    echo "Error: no .vlt.json found (run 'vlt init' first)"
    exit 1
  fi
  local addr
  addr=$(resolve_addr)
  # Determine environment
  if [ -z "$env" ]; then
    env=$(read_json "$config_file" '.default_env' "dev")
  fi
  # Get the secret path for this environment
  local secret_path
  secret_path=$(read_json "$config_file" ".environments.\"${env}\"")
  if [ -z "$secret_path" ]; then
    echo "Error: environment '${env}' not found in .vlt.json"
    echo "Available environments:"
    jq -r '.environments | keys[]' "$config_file"
    exit 1
  fi
  # Check for vault token
  if [ ! -f "$HOME/.vault-token" ] && [ -z "${VAULT_TOKEN:-}" ]; then
    echo "Error: not authenticated. Run 'vlt login' first."
    exit 1
  fi
  exec envconsul \
    -vault-addr="$addr" \
    -secret="$secret_path" \
    -no-prefix \
    -once \
    -- "${args[@]}"
}
cmd_status() {
  echo "── Config ──"
  local addr=""
  if config_file=$(find_config 2>/dev/null); then
    echo "Config file: $config_file"
    addr=$(read_json "$config_file" '.addr')
    local project
    project=$(read_json "$config_file" '.project')
    local default_env
    default_env=$(read_json "$config_file" '.default_env' "dev")
    echo "Address:     $addr"
    echo "Project:     $project"
    echo "Default env: $default_env"
    echo "Environments:"
    jq -r '.environments | to_entries[] | "  \(.key): \(.value)"' "$config_file"
  else
    echo "No .vlt.json found (run 'vlt init')"
    addr=$(read_global '.addr')
    if [ -n "$addr" ]; then
      echo "Global addr: $addr"
    fi
  fi
  local saved_username
  saved_username=$(read_global '.username')
  if [ -n "$saved_username" ]; then
    echo "Username:    $saved_username"
  fi
  echo ""
  echo "── Auth ──"
  if [ -z "$addr" ]; then
    addr=$(read_global '.addr')
  fi
  if [ -z "$addr" ]; then
    echo "No Vault address configured"
    return
  fi
  export VAULT_ADDR="$addr"
  if vault token lookup -format=json 2>/dev/null | jq -r '"Token valid, expires: \(.data.expire_time // "never")"' 2>/dev/null; then
    true
  else
    echo "Not authenticated (run 'vlt login')"
  fi
}
cmd_update() {
  local install_dir="$HOME/.local/bin"
  mkdir -p "$install_dir"
  echo "Updating vlt..."
  curl -fsSL "https://raw.githubusercontent.com/lattica/vlt/main/vlt" -o "$install_dir/vlt"
  chmod +x "$install_dir/vlt"
  echo "Updated to $(vlt --version)"
}
cmd_help() {
  cat <<'EOF'
vlt — Vault secret injector
Commands:
  vlt init                   Create .vlt.json in current directory
  vlt login                  Authenticate to Vault
  vlt run -- <command>       Inject secrets and run a command
  vlt run -e staging -- cmd  Use a specific environment
  vlt status                 Check auth and config
  vlt update                 Update vlt to the latest version
Examples:
  vlt init
  vlt login
  vlt run -- bun run --hot src/index.ts
  vlt run -e staging -- drizzle-kit migrate
  vlt run -e prod -- node dist/index.js
EOF
}
# Main
case "${1:-help}" in
init)
  shift
  cmd_init "$@"
  ;;
login)
  shift
  cmd_login "$@"
  ;;
run)
  shift
  cmd_run "$@"
  ;;
status)
  shift
  cmd_status "$@"
  ;;
update)
  shift
  cmd_update "$@"
  ;;
help | -h | --help) cmd_help ;;
-v | --version) echo "vlt 1.0.0" ;;
*)
  echo "Unknown command: $1"
  echo "Run 'vlt help' for usage"
  exit 1
  ;;
esac
